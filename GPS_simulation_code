% -----------STEP 1------------

% 1-1

% Reading the YUMA almanac from disk
localYumafile = "C:\Users\ilsan\Desktop\IPSA\AERO3\Aerospace project\almanac_yuma2.txt";
yumaText = fileread(localYumafile);

% Checking if there is HTML
if contains(lower(yumaText),'<html')
   disp("The file is not a raw YUMA")
end

% Splitting by satellite
blocks = regexp(lower(yumaText),'\\******** week 342 almanac for prn-[0-3][0-9] ********','split'); 
% There is an offset due to the presence of an empty space in the beginning of the text, so the first block is the 2nd Column
% But we will deal with than in the rest of the code

for i = 1:32

    block = strrep(blocks{i+1},' ',''); % To eliminate the offset of the blocks structure


    val1 = regexp(block,'id:\s*([-\d\.eE\+]+)','tokens');
    val2 = regexp(block,'health:\s*([-\d\.eE\+]+)','tokens');
    val3 = regexp(block,'eccentricity:\s*([-\d\.eE\+]+)','tokens');
    val4 = regexp(block,'timeofapplicability\(s\):\s*([-\d\.eE\+]+)','tokens');
    val5 = regexp(block,'orbitalinclination\(rad\):\s*([-\d\.eE\+]+)','tokens');
    val6 = regexp(block,'rateofrightascen\(r/s\):\s*([-\d\.eE\+]+)','tokens');
    val7 = regexp(block,'sqrt\(a\)\(m1/2\):\s*([-\d\.eE\+]+)','tokens');
    val8 = regexp(block,'rightascenatweek\(rad\):\s*([-\d\.eE\+]+)','tokens');
    val9 = regexp(block,'argumentofperigee\(rad\):\s*([-\d\.eE\+]+)','tokens');
    val10 = regexp(block,'meananom\(rad\):\s*([-\d\.eE\+]+)','tokens');
    val11 = regexp(block,'af0\(s\):\s*([-\d\.eE\+]+)','tokens');
    val12 = regexp(block,'af1\(s/s\):\s*([-\d\.eE\+]+)','tokens');
    val13 = regexp(block,'week:\s*([-\d\.eE\+]+)','tokens');

% Creating the structure

    s(i).PRN = str2double(val1{1}{1});
    s(i).Health = str2double(val2{1}{1});
    s(i).Eccentricity = str2double(val3{1}{1}) ;
    s(i).TimeOfApplicability = str2double(val4{1}{1});
    s(i).OrbitalInclination = str2double(val5{1}{1});
    s(i).RateOfRightAscend = str2double(val6{1}{1});
    s(i).SQRT_A = str2double(val7{1}{1});
    s(i).RightAscendAtWeek = str2double(val8{1}{1});
    s(i).ArgumentOfPerigee = str2double(val9{1}{1});
    s(i).MeanAnomaly = str2double(val10{1}{1});
    s(i).Af0 = str2double(val11{1}{1});
    s(i).Af1 = str2double(val12{1}{1});
    s(i).Week = str2double(val13{1}{1});
    
end
% Using a structure makes it easier to use a specific parameter from a specific satellite

% 1-2

% Converting UTC time into GPS week / seconds-of-week

tUTC = datetime(2025,2,19,0,0,0,'Timezone','UTC');      % Time chosen
epoch = datetime(1980,1,6,0,0,0,'TimeZone','UTC');      % Reference epoch
dt_UTC = seconds(tUTC - epoch) ;
WN = floor(dt_UTC/604800);
SOW = dt_UTC -WN*604800;

% Computing values of tk

tk = [];

for i = 1:32
    ToA = s.TimeOfApplicability ;
    delta_t = SOW - ToA;
    t =  mod(delta_t + 302400,604800) - 302400;
    tk(end+1) = t;
end

% ------------STEP 2-------------

% Computing n0 and values of Mk 

mu =  3.986004418e14;       % gravitational constant  
omegaE = 7.2921150e-5;      % angular speed of Earth's rotation

for i = 1:32
  e = s(i).Eccentricity;
  A = s(i).SQRT_A^2;
  n0 = sqrt(mu/A^3);
  Mk = s(i).MeanAnomaly + n0*tk(i);

% Newton method to find E

  E_l = [];
  E_l(1) = Mk;

  f = E_l(1)-e*sin(E_l(1)) - Mk;
  fp = 1 - e*cos(E_l(1));
  E_l(2) = E_l(1) - f/fp ;

  k = 2;
  while abs(E_l(k-1)-E_l(k))>10e-12 
    f = E_l(k)-e*sin(E_l(k)) - Mk;
    fp = 1 - e*cos(E_l(k));
    E_l(k+1) = E_l(k) - f/fp;
    k = k+1;
  end

  E = E_l(end);

  v = atan2(sqrt(1-e^2)*sin(E),cos(E)-e);
  u = s(i).ArgumentOfPerigee + v;
  r = A*(1-e*cos(E));
  xp = r*cos(u);
  yp = r*sin(u);

  Omega = s(i).RightAscendAtWeek + (s(i).RateOfRightAscend - omegaE)*tk(i)-omegaE*s(i).TimeOfApplicability;
  i0 = s(i).OrbitalInclination;

  x = xp*cos(Omega) - yp*cos(i0)*sin(Omega);
  y = xp*sin(Omega) - yp*cos(i0)*cos(Omega);
  z = yp*sin(i0);


  % Final ECEF coordinates
  sat_ECEF(i).XCoordinate = x;
  sat_ECEF(i).YCoordinate = y;
  sat_ECEF(i).ZCoordinate = z;

end

%-------------STEP 3-------------

user_LLA = [deg2rad(48.9),deg2rad(2.35),35];   % user LLA location (Paris)
mask = deg2rad(10);

% User ECEF coordinates (x_u, y_u, z_u)

a = 6378137;
f = 1/298.257223563;
e_2 = 2*f-f^2;

N = a/sqrt(1-e_2*sin(user_LLA(1))^2);

x_u = (N + user_LLA(3)) * cos(user_LLA(1)) * cos(user_LLA(2));
y_u = (N + user_LLA(3)) * cos(user_LLA(1)) * sin(user_LLA(2));
z_u = (N*(1 - e_2) + user_LLA(3))*sin(user_LLA(1));

user_ECEF = [x_u,y_u,z_u];

% LOS vector in ECEF 

s_vec = {};
rho = {};
el = {};
az = {};
e = {};
n = {};
u = {};
visibility = [];

for i = 1:32

    s_vec{i} = [sat_ECEF(i).XCoordinate - user_ECEF(1); sat_ECEF(i).YCoordinate - user_ECEF(2); sat_ECEF(i).ZCoordinate - user_ECEF(3)];

% User ENU coordinates (e,n,u)

    R_t = [ -sin(user_LLA(2)) , cos(user_LLA(2)) , 0; -sin(user_LLA(1))*cos(user_LLA(2)) , -sin(user_LLA(1))*sin(user_LLA(2)) , cos(user_LLA(1)) ; 
        cos(user_LLA(1))*cos(user_LLA(2)) , cos(user_LLA(1))*sin(user_LLA(2)) , sin(user_LLA(1)) ];
    R = R_t';

    ENU = R*s_vec{i}; 
    e{i} = ENU(1);
    n{i} = ENU(2);
    u{i} = ENU(3);

% Azimuth, elevation, range and visibility mask
    
    rho{i} = norm(s_vec{i});
    el{i} = atan2(u{i},sqrt(e{i}^2+n{i}^2));
    az{i} = mod(atan2(e{i},n{i}),2*pi);
    
    if el{i} >= mask
        visibility(i) = true;
    else
        visibility(i) = false;
    end

    disp(s_vec{i});
end



% ------------- STEP 4 --------------

% Rendering Earth

R_E = 6378137;
[XS,YS,ZS] = sphere(96);

XS = R_E * XS;
YS = R_E * YS;
ZS = R_E * ZS;

% Figure

figure 
surf(XS,YS,ZS,'FaceColor','white');
axis equal
view(35,20)
colormap('parula')
hold on
plot3(x_u,y_u,z_u,'b.','MarkerSize',12)
text(x_u,y_u,z_u,'User in Paris','Color','b')


for i = 1:32
    sat_X = sat_ECEF(i).XCoordinate ;
    sat_Y = sat_ECEF(i).YCoordinate ;
    sat_Z = sat_ECEF(i).ZCoordinate;
    if visibility(i) == true
        plot3(sat_X,sat_Y,sat_Z,'g.','MarkerSize',20);
        plot3([sat_X x_u],[sat_Y y_u],[sat_Z z_u],'g');
    else
        plot3(sat_X,sat_Y,sat_Z,'.','MarkerEdgeColor',[0.5 0.5 0.5],'MarkerSize',20);
    end 
end 
title('GPS constellation above Paris (snapshot)');
